generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

enum SessionMode {
  ONLINE
  IN_PERSON
}

enum AvailabilityStatus {
  AVAILABLE
  MAYBE
  UNAVAILABLE
}

enum UserGameSource {
  STEAM
  MANUAL
  IGDB
}

enum SessionGameSource {
  STEAM_MATCH
  MANUAL
  IGDB_SEARCH
  POPULAR
  TRENDING
  COMMON
  FRIEND_ADDED
}

enum SessionGameSignalType {
  OWNED
  AVAILABLE_TO_PLAY
  NOT_AVAILABLE
}

enum GameInterestSignal {
  WANT_TO_PLAY
  NEUTRAL
  NOT_TONIGHT
}

enum PriceAlertType {
  UNDER_PRICE
  GROUP_ON_SALE
  MISSING_PLAYERS_ONLY
  HISTORICAL_LOW
  OWNED_COUNT_DISCOUNTED
}

enum OAuthProvider {
  GOOGLE
}

enum FriendGroupMemberStatus {
  ACCEPTED
  PENDING
}

enum UserGameOwnership {
  UNKNOWN
  HAVE
  DONT_HAVE
}

enum UserGameInterest {
  WANT_TO_PLAY
  NEUTRAL
  NOT_INTERESTED
}

enum UserGamePlayedStatus {
  UNPLAYED
  PLAYING
  PLAYED
  COMPLETED
  DROPPED
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum CommitmentTier {
  ONE_SESSION
  UNDER_10_HOURS
  HOURS_10_TO_30
  HOURS_30_TO_100
  HOURS_100_TO_1000
  HOURS_1000_PLUS
  ENDLESS
}

enum ChallengeProgressStatus {
  SAVED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model Session {
  id                  String        @id @default(cuid())
  shareToken          String        @unique
  title               String
  mode                SessionMode
  requiredDuration    Int
  minimumPlayerCount  Int           @map("requiredPlayerCount")
  dateRangeStart      DateTime
  dateRangeEnd        DateTime
  dailyStartHour      Int
  dailyEndHour        Int
  weekendStartHour    Int?
  weekendEndHour      Int?
  timezone            String
  discordChannel      String?
  dealCountry         String        @default("GB")
  dealCurrency        String        @default("GBP")
  reminderPreferences Json
  lockedStartTime     DateTime?
  lockedEndTime       DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  participants        Participant[]
  games               SessionGame[]
  priceAlertRules     PriceAlertRule[]
  priceAlertEvents    PriceAlertEvent[]
  discordIntegrations DiscordIntegration[]
  discordNotifications DiscordNotificationLog[]
  discordAttendance   DiscordAttendance[]
}

model Participant {
  id        String                 @id @default(cuid())
  sessionId String
  session   Session                @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  discordUserId String?
  discordUsername String?
  isHost    Boolean                @default(false)
  createdAt DateTime               @default(now())
  responses AvailabilityResponse[]
  addedGames SessionGame[]
  gameSignals SessionGameSignal[]
  gameInterests SessionGameInterest[]
  preference ParticipantPreference?
  preferenceNudgeDismissedAt DateTime?
  discordAttendance DiscordAttendance[]

  @@index([sessionId])
  @@index([userId])
  @@index([sessionId, userId])
  @@unique([sessionId, discordUserId])
}

model DiscordIntegration {
  id              String   @id @default(cuid())
  sessionId       String
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  guildId         String
  channelId       String
  channelName     String?
  createdByUserId String?
  messageId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sessionId, guildId, channelId])
  @@index([guildId, channelId])
}

model DiscordNotificationLog {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  guildId     String?
  channelId   String?
  type        String
  scheduledFor DateTime?
  messageId   String?
  status      String
  error       String?
  createdAt   DateTime @default(now())

  @@unique([sessionId, type, scheduledFor])
  @@index([sessionId, type])
  @@index([scheduledFor, status])
}

model DiscordAttendance {
  id            String      @id @default(cuid())
  sessionId     String
  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantId String?
  participant   Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  discordUserId String
  discordUsername String?
  status        String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([sessionId, discordUserId])
  @@index([participantId])
}

model AvailabilityResponse {
  id            String             @id @default(cuid())
  participantId String
  participant   Participant        @relation(fields: [participantId], references: [id], onDelete: Cascade)
  slotStart     DateTime
  slotEnd       DateTime
  status        AvailabilityStatus
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([participantId, slotStart])
  @@index([slotStart])
}

model User {
  id            String         @id @default(cuid())
  displayName   String
  username      String?        @unique
  normalizedUsername String?   @unique
  usernameChangedAt DateTime?
  onboardingCompletedAt DateTime?
  email         String?
  emailVerified Boolean        @default(false)
  avatarUrl     String?
  favouriteGenres Json         @default("[]")
  directoryVisible Boolean     @default(true)
  lastSignedInAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      UserSession[]
  oauthAccounts OAuthAccount[]
  steamAccount  SteamAccount?
  games         UserGame[]
  sessionGames  SessionGame[]
  participants  Participant[]
  preference    UserPreference?
  sentFriendInvites FriendInvite[]
  friendsSent       UserFriend[] @relation("FriendUser")
  friendsReceived   UserFriend[] @relation("FriendFriend")
  ownedFriendGroups FriendGroup[] @relation("FriendGroupOwner")
  friendGroupMemberships FriendGroupMember[]
  sentFriendGroupInvites FriendGroupInvite[]
  usernameHistory UsernameHistory[]
  sentFriendRequests FriendRequest[] @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestRecipient")
  blocksCreated UserBlock[] @relation("UserBlocker")
  blocksReceived UserBlock[] @relation("UserBlocked")
  challengeProgress UserChallenge[]
  mergeIntentsCurrent AccountMergeIntent[] @relation("MergeCurrentUser")
  mergeIntentsOther AccountMergeIntent[] @relation("MergeOtherUser")
  avatarImage UserAvatar?

  @@index([email])
  @@index([normalizedUsername])
  @@index([directoryVisible, normalizedUsername])
}

model UserAvatar {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Bytes
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

model UsernameHistory {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  normalizedUsername String
  reservedUntil      DateTime
  createdAt          DateTime @default(now())

  @@unique([normalizedUsername])
  @@index([userId])
  @@index([reservedUntil])
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          OAuthProvider
  providerAccountId String
  email             String?
  emailVerified     Boolean       @default(false)
  avatarUrl         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model UserPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familiarVsNew         Int      @default(50)
  coOpVsCompetitive     Int      @default(75)
  priceImportance       Int      @default(50)
  genreImportance       Int      @default(50)
  ownershipImportance   Int      @default(75)
  backlogImportance     Int      @default(50)
  shortVsLong           Int      @default(50)
  chillVsIntense        Int      @default(50)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ParticipantPreference {
  id                    String      @id @default(cuid())
  participantId         String      @unique
  participant           Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  familiarVsNew         Int         @default(50)
  coOpVsCompetitive     Int         @default(75)
  priceImportance       Int         @default(50)
  genreImportance       Int         @default(50)
  ownershipImportance   Int         @default(75)
  backlogImportance     Int         @default(50)
  shortVsLong           Int         @default(50)
  chillVsIntense        Int         @default(50)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model UserSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model SteamAccount {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  steamId          String    @unique
  personaName      String?
  avatarUrl        String?
  lastImportAt     DateTime?
  lastImportStatus String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Game {
  id              String        @id @default(cuid())
  title           String
  normalizedTitle String
  slug            String?        @unique
  steamAppId      Int?          @unique
  igdbId          Int?          @unique
  itadId          String?        @unique
  coverUrl        String?
  summary         String?
  genres          Json          @default("[]")
  platforms       Json          @default("[]")
  gameModes       Json          @default("[]")
  popularityScore Float?
  steamReviewScore Int?
  steamReviewPercent Int?
  steamReviewTotal Int?
  steamReviewSummary String?
  qualitySource   String?
  qualityFetchedAt DateTime?
  minPlayers      Int?
  maxPlayers      Int?
  onlineCoop      Boolean?
  localCoop       Boolean?
  onlineMultiplayer Boolean?
  localMultiplayer Boolean?
  campaignCoop    Boolean?
  capabilitySource String?
  capabilityConfidence Float?
  timeToBeatHastilyMinutes Int?
  timeToBeatNormallyMinutes Int?
  timeToBeatCompletelyMinutes Int?
  timeToBeatCount Int?
  timeToBeatSource String?
  timeToBeatFetchedAt DateTime?
  minimumSessionMinutes Int?
  commitmentTier CommitmentTier?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userGames       UserGame[]
  sessionGames    SessionGame[]
  steamStorePrice SteamStorePrice?
  deal            GameDeal?
  capabilities    GameCapability[]
  challenges      GameChallenge[]

  @@index([normalizedTitle])
  @@index([normalizedTitle(ops: raw("gin_trgm_ops"))], type: Gin, map: "Game_normalizedTitle_trgm_idx")
}

model GameCapability {
  id                String   @id @default(cuid())
  gameId            String
  game              Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  platform          String
  minPlayers        Int?
  maxPlayers        Int?
  onlineMultiplayer Boolean?
  localMultiplayer  Boolean?
  onlineCoop        Boolean?
  localCoop         Boolean?
  campaignCoop      Boolean?
  source            String
  confidence        Float?
  fetchedAt         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([gameId, platform, source])
  @@index([gameId, platform])
}

model GameDeal {
  id              String   @id @default(cuid())
  gameId          String   @unique
  game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  itadId          String?
  currentPrice    Int?
  regularPrice    Int?
  discountPercent Int?
  currency        String?
  country         String?
  shopName        String?
  dealUrl         String?
  historicalLow   Int?
  historicalLow3m Int?
  historicalLow1y Int?
  status          String
  fetchedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([itadId])
  @@index([fetchedAt])
  @@index([country, fetchedAt, status])
}

model FriendInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  inviterId   String
  inviter     User      @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  acceptedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([inviterId])
  @@index([acceptedById])
  @@index([expiresAt])
}

model UserFriend {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("FriendUser", fields: [userId], references: [id], onDelete: Cascade)
  friendId  String
  friend    User     @relation("FriendFriend", fields: [friendId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
  @@index([friendId])
}

model FriendRequest {
  id          String              @id @default(cuid())
  senderId    String
  sender      User                @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User                @relation("FriendRequestRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([senderId, recipientId])
  @@index([recipientId, status])
  @@index([senderId, status])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("UserBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model AccountMergeIntent {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  currentUserId String
  currentUser   User     @relation("MergeCurrentUser", fields: [currentUserId], references: [id], onDelete: Cascade)
  otherUserId   String
  otherUser     User     @relation("MergeOtherUser", fields: [otherUserId], references: [id], onDelete: Cascade)
  provider      String
  expiresAt     DateTime
  confirmedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([currentUserId, expiresAt])
  @@index([otherUserId])
}

model FriendGroup {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation("FriendGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   FriendGroupMember[]
  invites   FriendGroupInvite[]

  @@index([ownerId])
}

model FriendGroupMember {
  id          String                  @id @default(cuid())
  groupId     String
  group       FriendGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName String
  status      FriendGroupMemberStatus @default(PENDING)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId, status])
}

model FriendGroupInvite {
  id          String       @id @default(cuid())
  token       String       @unique
  groupId     String
  group       FriendGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviterId   String
  inviter     User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  acceptedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@index([groupId])
  @@index([inviterId])
  @@index([acceptedById])
  @@index([expiresAt])
}

model SteamStorePrice {
  id              String   @id @default(cuid())
  gameId          String   @unique
  game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  steamAppId      Int      @unique
  currency        String?
  initialPrice    Int?
  finalPrice      Int?
  discountPercent Int?
  status          String
  fetchedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([fetchedAt])
}

model UserGame {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId           String
  game             Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  source           UserGameSource
  ownership        UserGameOwnership @default(HAVE)
  wishlist         Boolean        @default(false)
  favourite        Boolean        @default(false)
  rating           Int?
  interest         UserGameInterest @default(NEUTRAL)
  playedStatus     UserGamePlayedStatus @default(UNPLAYED)
  notes            String?
  playtimeMinutes  Int?
  recentlyPlayedAt DateTime?
  lastImportedAt   DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([userId, recentlyPlayedAt, playtimeMinutes])
}

model GameChallenge {
  id                  String   @id
  gameId              String
  game                Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  title               String
  description         String
  difficulty          Int
  minPlayers          Int
  maxPlayers          Int
  platform            String
  estimatedMinMinutes Int?
  estimatedMaxMinutes Int?
  caveat              String?
  sourceName          String
  sourceUrl           String
  verifiedAt          DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  progress            UserChallenge[]

  @@index([gameId])
  @@index([difficulty, minPlayers, maxPlayers])
}

model UserChallenge {
  id          String                  @id @default(cuid())
  userId      String
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   GameChallenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  status      ChallengeProgressStatus @default(SAVED)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([userId, challengeId])
  @@index([challengeId, status])
}

model SessionGame {
  id                   String              @id @default(cuid())
  sessionId            String
  session              Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  gameId               String
  game                 Game                @relation(fields: [gameId], references: [id], onDelete: Cascade)
  addedByParticipantId String?
  addedByParticipant   Participant?        @relation(fields: [addedByParticipantId], references: [id], onDelete: SetNull)
  addedByUserId        String?
  addedByUser          User?               @relation(fields: [addedByUserId], references: [id], onDelete: SetNull)
  source               SessionGameSource
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  signals              SessionGameSignal[]
  interests            SessionGameInterest[]

  @@unique([sessionId, gameId])
  @@index([gameId])
  @@index([addedByParticipantId])
  @@index([addedByUserId])
}

model PriceAlertRule {
  id              String         @id @default(cuid())
  sessionId       String
  session         Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdByParticipantId String?
  type            PriceAlertType
  thresholdPrice  Int?
  ownedCount      Int?
  totalCount      Int?
  missingOnly     Boolean        @default(false)
  enabled         Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  events          PriceAlertEvent[]

  @@index([sessionId])
  @@index([sessionId, enabled])
}

model PriceAlertEvent {
  id              String         @id @default(cuid())
  sessionId       String
  session         Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ruleId          String?
  rule            PriceAlertRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  gameId          String
  title           String
  message         String
  currentPrice    Int?
  historicalLow   Int?
  currency        String?
  url             String?
  triggeredAt     DateTime       @default(now())

  @@unique([sessionId, gameId, message])
  @@index([sessionId])
  @@index([ruleId])
}

model SessionGameSignal {
  id              String                @id @default(cuid())
  sessionGameId   String
  sessionGame     SessionGame           @relation(fields: [sessionGameId], references: [id], onDelete: Cascade)
  participantId   String
  participant     Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  signal          SessionGameSignalType
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([sessionGameId, participantId])
  @@index([participantId])
}

model SessionGameInterest {
  id              String             @id @default(cuid())
  sessionGameId   String
  sessionGame     SessionGame        @relation(fields: [sessionGameId], references: [id], onDelete: Cascade)
  participantId   String
  participant     Participant        @relation(fields: [participantId], references: [id], onDelete: Cascade)
  interest        GameInterestSignal
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([sessionGameId, participantId])
  @@index([participantId])
}
