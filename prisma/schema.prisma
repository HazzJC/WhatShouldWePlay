generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionMode {
  ONLINE
  IN_PERSON
}

enum AvailabilityStatus {
  AVAILABLE
  MAYBE
  UNAVAILABLE
}

enum UserGameSource {
  STEAM
  MANUAL
  IGDB
}

enum SessionGameSource {
  STEAM_MATCH
  MANUAL
  IGDB_SEARCH
  POPULAR
  TRENDING
  COMMON
  FRIEND_ADDED
}

enum SessionGameSignalType {
  OWNED
  AVAILABLE_TO_PLAY
  NOT_AVAILABLE
}

enum GameInterestSignal {
  WANT_TO_PLAY
  NEUTRAL
  NOT_TONIGHT
}

model Session {
  id                  String        @id @default(cuid())
  shareToken          String        @unique
  title               String
  mode                SessionMode
  requiredDuration    Int
  minimumPlayerCount  Int           @map("requiredPlayerCount")
  dateRangeStart      DateTime
  dateRangeEnd        DateTime
  dailyStartHour      Int
  dailyEndHour        Int
  weekendStartHour    Int?
  weekendEndHour      Int?
  timezone            String
  discordChannel      String?
  reminderPreferences Json
  lockedStartTime     DateTime?
  lockedEndTime       DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  participants        Participant[]
  games               SessionGame[]
}

model Participant {
  id        String                 @id @default(cuid())
  sessionId String
  session   Session                @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  isHost    Boolean                @default(false)
  createdAt DateTime               @default(now())
  responses AvailabilityResponse[]
  addedGames SessionGame[]
  gameSignals SessionGameSignal[]
  gameInterests SessionGameInterest[]
  preference ParticipantPreference?

  @@index([sessionId])
  @@index([userId])
}

model AvailabilityResponse {
  id            String             @id @default(cuid())
  participantId String
  participant   Participant        @relation(fields: [participantId], references: [id], onDelete: Cascade)
  slotStart     DateTime
  slotEnd       DateTime
  status        AvailabilityStatus
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([participantId, slotStart])
  @@index([slotStart])
}

model User {
  id            String         @id @default(cuid())
  displayName   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      UserSession[]
  steamAccount  SteamAccount?
  games         UserGame[]
  sessionGames  SessionGame[]
  participants  Participant[]
  preference    UserPreference?
}

model UserPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familiarVsNew         Int      @default(50)
  coOpVsCompetitive     Int      @default(75)
  priceImportance       Int      @default(50)
  genreImportance       Int      @default(50)
  ownershipImportance   Int      @default(75)
  backlogImportance     Int      @default(50)
  shortVsLong           Int      @default(50)
  chillVsIntense        Int      @default(50)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ParticipantPreference {
  id                    String      @id @default(cuid())
  participantId         String      @unique
  participant           Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  familiarVsNew         Int         @default(50)
  coOpVsCompetitive     Int         @default(75)
  priceImportance       Int         @default(50)
  genreImportance       Int         @default(50)
  ownershipImportance   Int         @default(75)
  backlogImportance     Int         @default(50)
  shortVsLong           Int         @default(50)
  chillVsIntense        Int         @default(50)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model UserSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model SteamAccount {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  steamId          String    @unique
  personaName      String?
  avatarUrl        String?
  lastImportAt     DateTime?
  lastImportStatus String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Game {
  id              String        @id @default(cuid())
  title           String
  normalizedTitle String
  steamAppId      Int?          @unique
  igdbId          Int?          @unique
  coverUrl        String?
  summary         String?
  genres          Json          @default("[]")
  platforms       Json          @default("[]")
  gameModes       Json          @default("[]")
  popularityScore Float?
  minPlayers      Int?
  maxPlayers      Int?
  onlineCoop      Boolean?
  localCoop       Boolean?
  capabilitySource String?
  capabilityConfidence Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userGames       UserGame[]
  sessionGames    SessionGame[]
  steamStorePrice SteamStorePrice?

  @@index([normalizedTitle])
}

model SteamStorePrice {
  id              String   @id @default(cuid())
  gameId          String   @unique
  game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  steamAppId      Int      @unique
  currency        String?
  initialPrice    Int?
  finalPrice      Int?
  discountPercent Int?
  status          String
  fetchedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([fetchedAt])
}

model UserGame {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId           String
  game             Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  source           UserGameSource
  playtimeMinutes  Int?
  recentlyPlayedAt DateTime?
  lastImportedAt   DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, gameId])
  @@index([gameId])
}

model SessionGame {
  id                   String              @id @default(cuid())
  sessionId            String
  session              Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  gameId               String
  game                 Game                @relation(fields: [gameId], references: [id], onDelete: Cascade)
  addedByParticipantId String?
  addedByParticipant   Participant?        @relation(fields: [addedByParticipantId], references: [id], onDelete: SetNull)
  addedByUserId        String?
  addedByUser          User?               @relation(fields: [addedByUserId], references: [id], onDelete: SetNull)
  source               SessionGameSource
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  signals              SessionGameSignal[]
  interests            SessionGameInterest[]

  @@unique([sessionId, gameId])
  @@index([gameId])
  @@index([addedByParticipantId])
  @@index([addedByUserId])
}

model SessionGameSignal {
  id              String                @id @default(cuid())
  sessionGameId   String
  sessionGame     SessionGame           @relation(fields: [sessionGameId], references: [id], onDelete: Cascade)
  participantId   String
  participant     Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  signal          SessionGameSignalType
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([sessionGameId, participantId])
  @@index([participantId])
}

model SessionGameInterest {
  id              String             @id @default(cuid())
  sessionGameId   String
  sessionGame     SessionGame        @relation(fields: [sessionGameId], references: [id], onDelete: Cascade)
  participantId   String
  participant     Participant        @relation(fields: [participantId], references: [id], onDelete: Cascade)
  interest        GameInterestSignal
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([sessionGameId, participantId])
  @@index([participantId])
}
