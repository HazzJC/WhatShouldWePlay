# --- Required ---------------------------------------------------------------
# Use the Neon *pooled* connection string in production (host ends in `-pooler`)
# with `?pgbouncer=true&connection_limit=1` so serverless functions stay within
# the free-tier connection budget.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Direct (non-pooled) connection used ONLY to run migrations on deploy
# (`prisma migrate deploy` can't run over pgbouncer). Set this to the Neon
# *direct* endpoint (host WITHOUT `-pooler`) when DATABASE_URL is pooled. If you
# use a single direct connection (e.g. local Postgres), leave this unset — the
# build falls back to DATABASE_URL.
DIRECT_URL=""

# Public base URL of the app. Set this in production — it is used to build share
# links and the Steam OpenID return URL, and must not be derived from request
# headers in a security-sensitive context.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Signs auth/session cookies. REQUIRED in production (the app throws on boot if
# it is missing). Generate with: openssl rand -base64 32
AUTH_COOKIE_SECRET="change-me-to-a-long-random-secret"

# --- Optional: game data & accounts -----------------------------------------
# Google sign-in for persistent cross-device accounts and saved friend groups.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Steam library import. Without it, the app falls back to the public Steam
# community profile feed and still degrades gracefully.
STEAM_WEB_API_KEY=""

# IGDB (via Twitch) for game search, popular and trending lists.
IGDB_CLIENT_ID=""
IGDB_CLIENT_SECRET=""

# IsThereAnyDeal for live prices, deals and sale alerts.
ITAD_API_KEY=""

# --- Optional: Discord integration ------------------------------------------
DISCORD_PUBLIC_KEY=""
DISCORD_BOT_TOKEN=""
DISCORD_APPLICATION_ID=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_INSTALL_URL=""
DISCORD_GUILD_ID=""

# --- Optional: scheduled reminders ------------------------------------------
# Protects the /api/cron/discord-reminders endpoint. REQUIRED for the cron to
# run — Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`. If it is
# unset the endpoint fails closed (503). Generate with: openssl rand -base64 32
CRON_SECRET=""
